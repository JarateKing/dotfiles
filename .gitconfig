[alias]
	# these exist as scripts, but we can use them via `git logs` now too
	logs = !"gitlogs"
	logx = !"gitlogx"
	diffs = !"gitdiffs"
	who = !"gitwho"
	aliases = !"gitaliases"
	list-files = !"gitlistfiles"
	churn = !"gitchurn"

	# these are common or useful commands that can have simplified syntax
	unstage = restore --staged
	uncommit = reset --soft HEAD~
	amend = commit --amend
	contributors = shortlog -n -s -e
	discard = checkout -p
	staging = add -p
	unstaging = restore --staged -p
	default-branch = !"git symbolic-ref refs/remotes/origin/HEAD | cut -f4 -d/"
	directory = rev-parse --show-toplevel
	
	# listing branches and tags
	branches = !"gitrefsall"
	local-branches = !"gitrefs refs/heads"
	remote-branches = !"gitrefs refs/remotes"
	tags = !"gitrefs refs/tags"

[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process

[push]
	autoSetupRemote = true

# for configurations like "user" that's personal
[include]
	path = .gitconfig-private
